# .env.example

# ================================
# DOMAIN & SSL CONFIGURATION
# ================================
# The base domain name for the application
# Example: mypos.com
DOMAIN=agrix.vn

# Email for Let's Encrypt SSL warnings
LETSENCRYPT_EMAIL=admin@agrix.vn

# ================================
# DATABASE (POSTGRES)
# ================================
POSTGRES_DB=agrix
POSTGRES_USER=agrix_user
POSTGRES_PASSWORD=super_secret_db_password
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public

# ================================
# BACKEND SECRETS
# ================================
# Keep this super secure, minimum 32 chars
JWT_SECRET=super_secret_jwt_key_here

# ================================
# MINIO / STORAGE
# ================================
MINIO_ACCESS_KEY=agrix_minio_admin
MINIO_SECRET_KEY=agrix_minio_super_secret
MINIO_URL=http://minio:9000

# ================================
# REDIS
# ================================
REDIS_PASSWORD=super_secret_redis_password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
