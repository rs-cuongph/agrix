# === PostgreSQL ===
POSTGRES_DB=agrix
POSTGRES_USER=agrix
POSTGRES_PASSWORD=agrix_secret

# === NestJS Backend ===
DATABASE_URL=postgres://agrix:agrix_secret@localhost:5432/agrix
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRATION=24h

# === MinIO (S3-compatible storage) ===
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=agrix-assets
MINIO_USE_SSL=false

# === App Config ===
APP_PORT=3000
NODE_ENV=development
