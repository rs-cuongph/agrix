# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgres://agrix:agrix_secret@localhost:5432/agrix

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-secure-random-string
JWT_EXPIRATION=24h

# ─── MinIO (Object Storage) ───────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=agrix-assets
MINIO_USE_SSL=false

# ─── App ──────────────────────────────────────────────────────────────────────
APP_PORT=3000
NODE_ENV=development

# ─── Encryption (AES-256) ─────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
AES_ENCRYPTION_KEY=replace-with-64-hex-chars-output-of-openssl-rand-hex-32

# ─── Webhook (Bank Transfer / Google Apps Script integration) ─────────────────
# Generate: openssl rand -hex 32
# Must match the secret configured in your Google Apps Script
WEBHOOK_SECRET=replace-with-64-hex-chars-output-of-openssl-rand-hex-32
